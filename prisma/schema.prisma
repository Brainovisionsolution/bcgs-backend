generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id               Int      @id @default(autoincrement())
  template_id      String   @unique // e.g. "MALE_01"
  name             String
  background_image String   // URL or local path
  signature_image  String?  // Optional Signature Image URL
  seal_image       String?  // Optional Seal Image URL
  layout_json              Json     // Coordinates and formatting
  orientation              String   @default("LANDSCAPE") // PORTRAIT, LANDSCAPE
  is_default_certificate   Boolean  @default(false)
  is_default_offer_letter  Boolean  @default(false)
  certificates             Certificate[]
  offerLetters             OfferLetter[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Certificate {
  id             Int      @id @default(autoincrement())
  certificate_id String   @unique // e.g. BRV-YYYY-PROGRAM_CODE-XXXX
  internship_id  String?  // Optional internship ID from CSV
  name           String
  email          String?
  gender         String   // MALE, FEMALE, NEUTRAL
  college        String
  course         String
  program_type   String   // Internship, Training, Bootcamp
  duration       String
  start_date     DateTime
  end_date       DateTime
  issue_date     DateTime @default(now())
  role           String
  qr_url         String
  status         String   @default("VALID") // VALID, REVOKED
  templateId     Int
  template       Template @relation(fields: [templateId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OfferLetter {
  id             Int      @id @default(autoincrement())
  offer_id       String   @unique
  internship_id  String
  name           String
  email          String?
  college        String
  course         String
  program_type   String   
  duration       String
  start_date     DateTime
  end_date       DateTime
  issue_date     DateTime @default(now())
  role           String
  qr_url         String
  status         String   @default("GENERATED") // GENERATED, SENT, REVOKED
  templateId     Int
  template       Template @relation(fields: [templateId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
